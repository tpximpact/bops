{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "pagination": {
      "$ref": "#/definitions/PostSubmissionPagination"
    },
    "summary": {
      "type": "object",
      "properties": {
        "totalComments": {
          "type": "integer"
        },
        "totalConsulted": {
          "type": "integer"
        },
        "sentiment": {
          "type": "object",
          "properties": {
            "approved": {
              "type": "integer"
            },
            "amendmentsNeeded": {
              "type": "integer"
            },
            "objected": {
              "type": "integer"
            }
          }
        }
      },
      "required": ["totalComments", "totalConsulted", "sentiment"]
    },
        "comments": {
      "type": "object",
      "properties": {
        "specialists": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "organisationSpecialism": { "type": ["string", "null"] },
              "jobTitle": { "type": ["string", "null"] },
              "reason": { "type": "string" },
              "constraints": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": { "type": "object" }
                }
              },
              "firstConsultedAt": { "type": "string", "format": "date-time" },
              "comments": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "sentiment": { "type": "string" },
                    "commentRedacted": { "type": "string" },
                    "metadata": {
                      "type": "object",
                      "properties": {
                        "submittedAt": { "type": "string", "format": "date-time" },
                        "validatedAt": { "type": ["string", "null"], "format": "date-time" },
                        "publishedAt": { "type": ["string", "null"], "format": "date-time" }
                      },
                      "required": ["submittedAt", "validatedAt", "publishedAt"]
                    }
                  },
                  "required": ["id", "sentiment", "commentRedacted", "metadata"]
                }
              }
            },
            "required": ["id", "organisationSpecialism", "jobTitle", "reason", "firstConsultedAt", "comments"]
          }
        }
      },
      "required": ["specialists"]
    }
  },
  "required": ["pagination", "summary", "comments"]
}